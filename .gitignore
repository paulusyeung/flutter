# Local dev pre-fill for the login screen (see dev.json.example)
dev.json

# Debug-only diagnostics log written by DiagnosticsLog (lib/app/diagnostics_log.dart).
# Lives under path_provider.getApplicationSupportDirectory() in normal runs, but
# also matched here so it never lands in the repo if a developer's setup
# resolves the directory inside the working tree.
claude-diagnostics.log
claude-diagnostics.log.*

# SQLite/Drift database files should never live in the working tree — the real DB lives in
# getApplicationSupportDirectory() (native), IndexedDB (web), or memory (tests). A stray
# database.db can appear if drift tooling/codegen is run from the repo root.
*.db
*.db-shm
*.db-wal
*.db.broken.*

key.properties
key.jks