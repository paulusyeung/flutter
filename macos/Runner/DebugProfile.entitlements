<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
	Debug-vs-Release asymmetries (intentional):
	  * `cs.allow-jit` and `network.server` are Debug-only — required by
	    Flutter's hot-reload tooling. Do NOT copy them into Release.
	  * `com.apple.developer.applesignin` is Release-only (commented out
	    below) — Apple's dev provisioning profile doesn't include it, and
	    enabling it here breaks debug builds. The login screen catches the
	    missing capability and shows "Apple sign-in unavailable" in dev.
-->
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- Required by image_picker + file_picker (Company Details: Logo,
	     Documents). Without this, the sandbox blocks the file open panels
	     and the plugins log NSCocoaErrorDomain errors. Same shape as the
	     keychain-access-groups note below. -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.invoiceninja.admin</string>
	</array>
	<!--
		Sign in with Apple: re-enable this once the bundle id has the
		capability provisioned in Apple Developer. Until then the default
		"Mac Team Provisioning Profile: *" doesn't include it and the build
		fails. The login screen still renders the Apple button; tapping it
		surfaces "Apple sign-in unavailable" via the catch in
		LoginViewModel.submitApple().

		<key>com.apple.developer.applesignin</key>
		<array><string>Default</string></array>
	-->
</dict>
</plist>
